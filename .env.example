# ============================================================
#  Supabase Postgres – connection strings pre Drizzle ORM
#  Hodnoty nájdeš v: Supabase Dashboard
#    -> Project Settings -> Database -> Connection string
#  Nahraď [PROJECT-REF], [PASSWORD] a [REGION].
#  Reálne hodnoty patria do .env.local (NIE do gitu).
# ============================================================

# DATABASE_URL = runtime spojenie pre Next.js (serverless / edge).
# Supavisor "Transaction" pooler, port 6543, IPv4.
# POZOR: v src/db/index.ts MUSÍ byť postgres(url, { prepare: false }),
#        lebo transaction pooler nepodporuje prepared statements.
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres"

# DIRECT_URL = priame / session spojenie pre migrácie (drizzle-kit).
# Supavisor "Session" pooler, port 5432, IPv4 – podporuje prepared
# statements a DDL.
DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres"

# Alternatíva pre DIRECT_URL – úplne priame spojenie na DB host
# (port 5432, IPv6; na IPv4-only sieti treba IPv4 add-on):
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ============================================================
#  Seed (npm run db:seed) – bootstrap admin
#  1. Založ admina v Supabase Dashboard -> Authentication -> Add user
#  2. Skopíruj jeho User UID sem (users.id = auth.users.id, nikdy
#     sa negeneruje lokálne – viď bootstrap pravidlo v schéme)
# ============================================================
SEED_ADMIN_ID="[AUTH-USER-UUID]"
SEED_ADMIN_EMAIL="admin@bamipa.sk"
SEED_ADMIN_NAME="Admin"
